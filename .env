# ================== 数据库和 Redis（主机端口，用于本地测试或外部工具） ==================
DATABASE_URL=postgresql://rjcut:rjcut_secret_2024@localhost:5433/rjcut
REDIS_URL=redis://localhost:6380/0

# ================== MinIO 配置 ==================
# 容器内部通信用（api、worker 等 Docker 服务连接 MinIO 时使用）
MINIO_ENDPOINT=localhost:9003

# 访问密钥（保持不变）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rjcut
MINIO_USE_SSL=false

# 外部访问地址（用于生成 presigned URL，让浏览器或外部用户能访问文件）
MINIO_EXTERNAL_ENDPOINT=http://localhost:9003

# 其他配置
TASK_TIMEOUT_SECONDS=3600
TASK_STALE_CHECK_INTERVAL=60
SECRET_KEY=change_me_in_production_2024
RQ_QUEUE_NAME=rjcut_tasks